# ─────────────────────────────────────────────────────────────
# ENO Portal — Variables de Entorno
# Copia este archivo a ".env" y completa los valores
# NUNCA subas el archivo .env a Git
# ─────────────────────────────────────────────────────────────

# ── Base de Datos PostgreSQL (Supabase) ───────────────────────
# Obtén estos valores en: Supabase Dashboard → Project Settings → Database
# Usa el "Connection string" en formato:
#   postgresql+psycopg2://[user]:[password]@[host]:[port]/[db_name]
DB_HOST=db.xxxxxxxxxxxxxxxxxxxx.supabase.co
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=tu_password_de_supabase
DB_NAME=postgres

# ── Servidor ─────────────────────────────────────────────────
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# ── CORS - Orígenes permitidos ────────────────────────────────
# En desarrollo local:
ALLOWED_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,http://localhost:3000
# En producción (Render), agregar también la URL del frontend:
# ALLOWED_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,https://eno-portal-frontend.onrender.com

# ── Credenciales de Administrador ────────────────────────────
ADMIN_EMAIL=ADMIN@ENO.COM
ADMIN_PHONE=8498888888
