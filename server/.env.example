# ─────────────────────────────────────────────────────────────
# ENO Portal V2 — Variables de Entorno
# Copia este archivo a ".env" y completa los valores
# NUNCA subas el archivo .env a Git
# ─────────────────────────────────────────────────────────────

# ── Base de Datos PostgreSQL (Supabase) ───────────────────────
DB_HOST=aws-0-us-east-1.pooler.supabase.com
DB_PORT=6543
DB_USER=postgres.tuprojectid
DB_PASSWORD=tu_password_de_supabase
DB_NAME=postgres

# ── CORS - Orígenes permitidos ────────────────────────────────
# Separar múltiples URLs con comas, sin espacios
ALLOWED_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,https://eno-portal-frontend.onrender.com

# ── URL del Frontend (para los enlaces en los correos) ────────
FRONTEND_URL=https://eno-portal-frontend.onrender.com

# ── Resend — Envío de Correos (API HTTP) ─────────────────────
# Crea una cuenta gratis en https://resend.com y obtén tu API Key
RESEND_API_KEY=re_xxxxxxxx_xxxxxxxxxxxxxxxxxxxxxxxx
# Usa "onboarding@resend.dev" mientras no verifiques tu propio dominio
RESEND_FROM_EMAIL=onboarding@resend.dev

# ── Supabase Storage ──────────────────────────────────────────
# Obtén en: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://tuprojectid.supabase.co
# Usa la "service_role" key (NO la anon key) para Storage
SUPABASE_SERVICE_KEY=eyJhbGc...

# ── Credenciales de Administrador ────────────────────────────
ADMIN_EMAIL=admin@eno.com
ADMIN_PHONE=8498888888
